{
  "name": "ai-video-studio",
  "version": "1.0.0",
  "description": "AI 영상 제작을 쉽고 빠르게 TB M TOOL",
  "main": "out/main/index.js",
  "author": "toolb",
  "license": "MIT",
  "build": {
    "appId": "com.toolb.aivideostudio",
    "productName": "TB MTOOL",
    "icon": "build/icon",
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "files": [
      "out/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**",
      "**/node_modules/ffprobe-static/**"
    ],
    "publish": {
      "provider": "github",
      "owner": "bitcory",
      "repo": "tbmultytool"
    },
    "win": {
      "target": "nsis",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": "dmg",
      "artifactName": "${productName}-${version}.${ext}"
    }
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "package": "electron-vite build && electron-builder --dir",
    "release": "electron-vite build && electron-builder --publish always",
    "release:mac:local": "electron-vite build && electron-builder --mac --publish never"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "lucide-react": "^1.17.0"
  },
  "devDependencies": {
    "@types/ffprobe-static": "^2.0.3",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "zustand": "^5.0.2"
  }
}
