{
  "manifest_version": 3,
  "name": "TB MTOOL Companion",
  "version": "0.1.13",
  "description": "TB MTOOL 앱의 생성 작업(ChatGPT·Grok·Suno 등)을 사용자 크롬에서 자동 실행하고, 결과를 앱으로 보냅니다 (로컬 전용).",
  "permissions": [
    "storage",
    "contextMenus",
    "tabs",
    "alarms"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://*.oaiusercontent.com/*",
    "https://labs.google/*",
    "https://*.googleusercontent.com/*",
    "https://*.usercontent.google.com/*",
    "https://*.gstatic.com/*",
    "https://grok.com/*",
    "https://*.grok.com/*",
    "https://*.x.ai/*",
    "https://suno.com/*",
    "https://*.suno.com/*",
    "https://*.suno.ai/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://labs.google/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "automate.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://grok.com/*"
      ],
      "js": [
        "grok.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://suno.com/*"
      ],
      "js": [
        "suno.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "TB MTOOL Companion"
  }
}
